{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "jsx": "preserve",
    "lib": [
      "ES2020",
      "dom",
      "dom.iterable"
    ],
    "incremental": true,
    "rootDir": ".",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
